@using SV22T1020328.Models.Sales
@model List<OrderDetailViewInfo>

@{
    ViewData["Title"] = "Giỏ hàng";
    var totalAmount = Model.Sum(x => x.TotalPrice);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Giỏ hàng của bạn</h4>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary btn-sm">
        Tiếp tục mua sắm
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Giỏ hàng đang trống.
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Về trang chủ</a>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="min-width:280px;">Sản phẩm</th>
                        <th class="text-center" style="width:140px;">Số lượng</th>
                        <th class="text-end" style="width:150px;">Đơn giá</th>
                        <th class="text-end" style="width:170px;">Thành tiền</th>
                        <th class="text-center" style="width:140px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex gap-2 align-items-center">
                                    <img src="~/images/products/@(string.IsNullOrWhiteSpace(item.Photo) ? "nophoto.png" : item.Photo)"
                                         asp-append-version="true"
                                         style="width:56px;height:56px;object-fit:cover;border-radius:8px;" />
                                    <div>
                                        <div class="fw-semibold">@item.ProductName</div>
                                        <small class="text-muted">@item.Unit</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <form asp-action="UpdateCart" method="post" class="d-flex gap-2 justify-content-center">
                                    <input type="hidden" name="productID" value="@item.ProductID" />
                                    <input type="hidden" name="salePrice" value="@item.SalePrice" />
                                    <input type="number" name="quantity" min="0" value="@item.Quantity" class="form-control form-control-sm" style="max-width:80px;" />
                                    <button class="btn btn-outline-secondary btn-sm" type="submit">Cập nhật</button>
                                </form>
                            </td>
                            <td class="text-end">@item.SalePrice.ToString("N0") đ</td>
                            <td class="text-end fw-semibold">@item.TotalPrice.ToString("N0") đ</td>
                            <td class="text-center">
                                <form asp-action="RemoveFromCart" method="post" class="d-inline">
                                    <input type="hidden" name="productID" value="@item.ProductID" />
                                    <button class="btn btn-outline-danger btn-sm" type="submit">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                        <td class="text-end fw-bold text-danger">@totalAmount.ToString("N0") đ</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="card-body d-flex flex-wrap gap-2 justify-content-end">
            <form asp-action="ClearCart" method="post">
                <button class="btn btn-outline-danger" type="submit">Xóa toàn bộ giỏ</button>
            </form>
            <a asp-action="Checkout" class="btn btn-primary">Tiến hành đặt hàng</a>
        </div>
    </div>
}