@using SV22T1020328.Models.Sales
@{
    ViewData["Title"] = "Trang chủ";
    var topProducts = ViewBag.TopProducts as List<OrderDetailViewInfo> ?? new List<OrderDetailViewInfo>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<div id="homeHeroCarousel" class="carousel slide hero-carousel mb-4" data-bs-ride="carousel" data-bs-interval="4500">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#homeHeroCarousel" data-bs-slide-to="0" class="active" aria-current="true"></button>
        <button type="button" data-bs-target="#homeHeroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#homeHeroCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner rounded-4 shadow-sm">

        <!-- Banner 1: Tông đỏ nâu → chữ trắng, nút vàng nổi bật -->
        <div class="carousel-item active">
            <img src="~/images/banners/banner-1.jpg" class="d-block w-100 hero-image" alt="Banner 1" />
            <div class="carousel-caption text-start hero-caption-1">
                <span class="hero-badge">Hot Deal</span>
                <h2 class="fw-bold mt-2">Mua sắm thông minh<br>Tiết kiệm hơn mỗi ngày</h2>
                <p class="mb-3">Hàng ngàn sản phẩm ưu đãi – giỏ hàng của bạn đang chờ!</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-warning px-4 fw-semibold">Mua ngay →</a>
            </div>
        </div>

        <!-- Banner 2: Tông tím navy → chữ trắng, nút trắng -->
        <div class="carousel-item">
            <img src="~/images/banners/banner-2.jpg" class="d-block w-100 hero-image" alt="Banner 2" />
            <div class="carousel-caption text-start hero-caption-2">
                <span class="hero-badge hero-badge-light">Chính hãng 100%</span>
                <h2 class="fw-bold mt-2">Sản phẩm chất lượng<br>Giá tốt nhất thị trường</h2>
                <p class="mb-3">Đặt hàng dễ dàng – giao hàng nhanh toàn quốc.</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-light px-4 fw-semibold text-primary">Khám phá →</a>
            </div>
        </div>

        <!-- Banner 3: Tông vàng cam → overlay tối hơn, chữ trắng, nút outline -->
        <div class="carousel-item">
            <img src="~/images/banners/banner-3.jpg" class="d-block w-100 hero-image" alt="Banner 3" />
            <div class="carousel-caption text-start hero-caption-3">
                <span class="hero-badge hero-badge-dark">Xu hướng mới</span>
                <h2 class="fw-bold mt-2">Ưu đãi mỗi ngày<br>tại TTP Shop</h2>
                <p class="mb-3">Nhiều sản phẩm bán chạy – khuyến mãi hấp dẫn.</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-dark px-4 fw-semibold">Xem ngay →</a>
            </div>
        </div>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="usp-card h-100">
            <i class="bi bi-patch-check-fill text-primary"></i>
            <h6>Sản phẩm chính hãng</h6>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="usp-card h-100">
            <i class="bi bi-truck text-primary"></i>
            <h6>Giao nhanh toàn quốc</h6>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="usp-card h-100">
            <i class="bi bi-arrow-repeat text-primary"></i>
            <h6>Đổi trả trong 7 ngày</h6>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="usp-card h-100">
            <i class="bi bi-headset text-primary"></i>
            <h6>Hỗ trợ 24/7</h6>
        </div>
    </div>
</div>

@if (topProducts.Any())
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white">
            <h5 class="mb-0 fw-bold text-primary">
                <i class="bi bi-fire me-1"></i>Top sản phẩm bán chạy
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                @foreach (var p in topProducts)
                {
                    var rating = 4 + (p.ProductID % 2);
                    var reviewCount = 50 + (p.ProductID % 150);
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="card h-100 border-0 shadow-sm product-card">
                            <div class="product-image-wrap">
                                <img class="card-img-top product-thumb"
                                     src="~/images/products/@(string.IsNullOrWhiteSpace(p.Photo) ? "nophoto.png" : p.Photo)"
                                     asp-append-version="true"
                                     alt="@p.ProductName" />
                            </div>
                            <div class="card-body d-flex flex-column p-3">
                                <h6 class="card-title fw-semibold mb-2 product-title">@p.ProductName</h6>
                                <div class="small mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= rating)
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-warning"></i>
                                        }
                                    }
                                    <span class="text-muted ms-1">(@reviewCount)</span>
                                </div>
                                <div class="text-danger fw-bold mb-2">@p.SalePrice.ToString("N0") đ</div>
                                <div class="small text-muted mb-3">Đã bán: @p.Quantity</div>
                                <div class="mt-auto d-flex gap-2">
                                    <a class="btn btn-outline-primary btn-sm flex-grow-1"
                                       asp-controller="Product"
                                       asp-action="Details"
                                       asp-route-id="@p.ProductID">Chi tiết</a>
                                    <button class="btn btn-primary btn-sm flex-grow-1"
                                            onclick="return shop.addToCart(@p.ProductID, 1)">
                                        Thêm giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}