@{
    Layout = null;
    ViewData["Title"] = "Đăng ký";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] - TNP Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-page d-flex align-items-center justify-content-center p-3">
    <div class="card auth-card w-100">
        <div class="card-body">
            <h4 class="fw-bold mb-1">Đăng ký tài khoản</h4>
            <p class="text-muted mb-4">Tạo tài khoản để bắt đầu mua sắm</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger py-2"></div>
            }

            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input name="email" type="email" class="form-control" placeholder="name@example.com" autocomplete="email" />
                </div>
                <div class="mb-3">  
                    <label class="form-label">Mật khẩu</label>
                    <input name="password" type="password" class="form-control" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Xác nhận mật khẩu</label>
                    <input name="confirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu" autocomplete="new-password" />
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-person-plus me-1"></i> Tạo tài khoản
                </button>
            </form>

            <div class="text-center mt-3">
                <span class="text-muted">Đã có tài khoản?</span>
                <a asp-action="Login" class="text-decoration-none fw-semibold">Đăng nhập</a>
            </div>

            <div class="text-center mt-2">
                <a asp-controller="Home" asp-action="Index" class="small text-muted text-decoration-none">← Quay về trang chủ</a>
            </div>
        </div>
    </div>
</body>
</html>