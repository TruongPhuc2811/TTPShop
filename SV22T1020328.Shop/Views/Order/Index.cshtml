@using SV22T1020328.Models.Sales
@model List<OrderViewInfo>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
    var currentStatus = (OrderStatusEnum)(ViewBag.Status ?? OrderStatusEnum.All);

    string StatusText(OrderStatusEnum status) => status switch
    {
        OrderStatusEnum.New => "Chờ duyệt",
        OrderStatusEnum.Accepted => "Đã duyệt",
        OrderStatusEnum.Shipping => "Đang giao",
        OrderStatusEnum.Completed => "Hoàn tất",
        OrderStatusEnum.Cancelled => "Đã hủy",
        OrderStatusEnum.Rejected => "Từ chối",
        _ => "Tất cả"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 order-page-header">
    <div>
        <h4 class="mb-1 fw-bold">Đơn hàng của tôi</h4>
        <div class="text-muted">Theo dõi trạng thái đơn hàng nhanh chóng</div>
    </div>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary">Mua thêm</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card border-0 shadow-sm mb-3 order-filter-card">
    <div class="card-body">
        <form id="orderFilterForm">
            <input type="hidden" id="statusFilter" name="status" value="@((int)currentStatus)" />

            <div class="d-flex flex-wrap gap-2 order-status-chips">
                @foreach (OrderStatusEnum s in Enum.GetValues(typeof(OrderStatusEnum)))
                {
                    var isActive = s == currentStatus;
                    <button type="button"
                            class="btn btn-sm @(isActive ? "btn-primary" : "btn-outline-primary") js-order-status"
                            data-status="@((int)s)">
                        @StatusText(s)
                    </button>
                }
            </div>
        </form>
    </div>
</div>

<div id="orderResult">
    @await Html.PartialAsync("OrderSearchResult", Model)
</div>

@section Scripts {
    <script>
        function loadOrders() {
            const query = $("#orderFilterForm").serialize();
            $.get("/Order/Search", query, function (html) {
                $("#orderResult").html(html);
            });
        }

        $(document).on("click", ".js-order-status", function () {
            $(".js-order-status").removeClass("btn-primary").addClass("btn-outline-primary");
            $(this).removeClass("btn-outline-primary").addClass("btn-primary");
            $("#statusFilter").val($(this).data("status"));
            loadOrders();
        });
    </script>
}
