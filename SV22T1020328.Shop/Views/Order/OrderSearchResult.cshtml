@model List<OrderViewInfo>

@{
    string StatusText(OrderStatusEnum status) => status switch
    {
        OrderStatusEnum.New => "Chờ duyệt",
        OrderStatusEnum.Accepted => "Đã duyệt",
        OrderStatusEnum.Shipping => "Đang giao",
        OrderStatusEnum.Completed => "Hoàn tất",
        OrderStatusEnum.Cancelled => "Đã hủy",
        OrderStatusEnum.Rejected => "Từ chối",
        _ => "Tất cả"
    };

    string StatusBadge(OrderStatusEnum status) => status switch
    {
        OrderStatusEnum.New => "bg-primary",
        OrderStatusEnum.Accepted => "bg-info text-dark",
        OrderStatusEnum.Shipping => "bg-warning text-dark",
        OrderStatusEnum.Completed => "bg-success",
        OrderStatusEnum.Cancelled => "bg-secondary",
        OrderStatusEnum.Rejected => "bg-danger",
        _ => "bg-dark"
    };
}

@if (!Model.Any())
{
    <div class="alert alert-info mb-0">Không có đơn hàng theo trạng thái đã chọn.</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Thời gian đặt</th>
                        <th>Địa chỉ giao hàng</th>
                        <th class="text-end">Tổng tiền</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center" style="width:120px;">Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">#@item.OrderID</td>
                            <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.DeliveryAddress, @item.DeliveryProvince</td>
                            <td class="text-end text-danger fw-semibold">@item.SumPrice.ToString("N0") đ</td>
                            <td class="text-center">
                                <span class="badge @StatusBadge(item.Status)">@StatusText(item.Status)</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.OrderID" class="btn btn-sm btn-outline-primary">Xem</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}