@using SV22T1020328.Shop
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TTP Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="shop-header sticky-top">
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-logo"><i class="bi bi-bag-heart"></i></span>
                    <span>TTP Shop</span>
                </a>

                <button class="navbar-toggler border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <i class="bi bi-list fs-3"></i>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto gap-lg-2">
                        <li class="nav-item"><a class="nav-link app-nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link app-nav-link" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        <li class="nav-item"><a class="nav-link app-nav-link" asp-controller="Order" asp-action="Index">Đơn hàng</a></li>
                    </ul>

                    <ul class="navbar-nav align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="btn app-cart-btn position-relative" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3 me-1"></i> Giỏ hàng
                                <span id="cartCountBadge" class="badge rounded-pill bg-warning text-dark ms-1">
                                    @ShoppingCartHelper.GetCartItemCount()
                                </span>
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Thông tin cá nhân</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">Đổi mật khẩu</a></li>
                                    <li><a class="dropdown-item" asp-controller="Order" asp-action="Index">Lịch sử mua hàng</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="btn btn-light btn-sm px-3" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                            <li class="nav-item"><a class="btn btn-warning btn-sm px-3" asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @RenderBody()
    </main>

    <footer class="shop-footer mt-4">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="footer-title">TNP Shop</h5>
                    <p class="mb-2">Nơi mua sắm tiện lợi, giao diện thân thiện, sản phẩm đa dạng và dịch vụ tận tâm.</p>
                    <p class="mb-0 small text-white-50">Mang trải nghiệm mua sắm hiện đại đến từng khách hàng.</p>
                </div>

                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-subtitle">Liên kết nhanh</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                        <li><a asp-controller="Order" asp-action="Index">Đơn hàng</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="footer-subtitle">Thông tin liên hệ</h6>
                    <ul class="list-unstyled footer-contact mb-0">
                        <li><i class="bi bi-geo-alt me-2"></i>Hà Nội, Việt Nam</li>
                        <li><i class="bi bi-telephone me-2"></i>0123 456 789</li>
                        <li><i class="bi bi-envelope me-2"></i>support@tnpshop.vn</li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="footer-subtitle">Kết nối với chúng tôi</h6>
                    <div class="d-flex gap-2">
                        <a href="#" class="social-btn"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-btn"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-btn"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="social-btn"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
            </div>

            <hr class="border-light-subtle my-4" />
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 small text-white-50">
                <span>© 2026 TNP Shop. All rights reserved.</span>
                <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>