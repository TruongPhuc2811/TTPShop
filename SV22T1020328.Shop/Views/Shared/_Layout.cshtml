@using SV22T1020328.Shop
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TTP Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ===== TOP BAR ===== -->
    <div class="topbar">
        <div class="container d-flex justify-content-between align-items-center">
            <span><i class="bi bi-telephone-fill me-1"></i>0123 456 789 &nbsp;|&nbsp; <i class="bi bi-envelope-fill me-1"></i>support@@ttpshop.vn</span>
            <span><i class="bi bi-truck me-1"></i>Miễn phí vận chuyển đơn từ 500k &nbsp;|&nbsp; <i class="bi bi-arrow-repeat me-1"></i>Đổi trả 7 ngày</span>
        </div>
    </div>

    <!-- ===== HEADER / NAVBAR ===== -->
    <header class="shop-header sticky-top">
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">

                <!-- Brand -->
                <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-logo">
                        <i class="bi bi-bag-heart-fill"></i>
                    </span>
                    <span class="brand-text">TTP<span class="brand-accent">Shop</span></span>
                </a>

                <!-- Mobile toggle -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <i class="bi bi-list fs-2 text-white"></i>
                </button>

                <!-- Nav links -->
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1 d-lg-none"></i>Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Product" asp-action="Index">
                                <i class="bi bi-grid me-1 d-lg-none"></i>Sản phẩm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Order" asp-action="Index">
                                <i class="bi bi-receipt me-1 d-lg-none"></i>Đơn hàng
                            </a>
                        </li>
                    </ul>

                    <!-- Right actions -->
                    <ul class="navbar-nav align-items-lg-center gap-lg-2">
                        <!-- Cart -->
                        <li class="nav-item">
                            <a class="app-cart-btn" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3"></i>
                                <span class="cart-label">Giỏ hàng</span>
                                <span id="cartCountBadge" class="cart-badge">
                                    @ShoppingCartHelper.GetCartItemCount()
                                </span>
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <!-- User dropdown -->
                            <li class="nav-item dropdown">
                                <a class="app-user-btn dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle user-icon"></i>
                                    <span class="d-none d-lg-inline">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end user-dropdown shadow border-0">
                                    <li class="dropdown-header-info px-3 py-2 mb-1">
                                        <div class="fw-600">@User.Identity.Name</div>
                                        <div class="text-muted small">Thành viên TTP Shop</div>
                                    </li>
                                    <li><hr class="dropdown-divider my-1" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="bi bi-person me-2 text-primary"></i>Thông tin cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                                            <i class="bi bi-shield-lock me-2 text-primary"></i>Đổi mật khẩu
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Order" asp-action="Index">
                                            <i class="bi bi-clock-history me-2 text-primary"></i>Lịch sử mua hàng
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-1" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm px-3 rounded-pill" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-person me-1"></i>Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-warning btn-sm px-3 rounded-pill fw-600" asp-controller="Account" asp-action="Register">
                                    Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="container py-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="shop-footer mt-5">

        <!-- Footer wave top -->
        <div class="footer-wave">
            <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
                <path d="M0,40 C240,70 480,10 720,40 C960,70 1200,10 1440,40 L1440,60 L0,60 Z" fill="#0f172a" />
            </svg>
        </div>

        <div class="footer-body">
            <div class="container">
                <div class="row g-5">

                    <!-- Brand col -->
                    <div class="col-lg-4 col-md-6">
                        <div class="footer-brand mb-3">
                            <span class="footer-brand-logo"><i class="bi bi-bag-heart-fill"></i></span>
                            <span class="footer-brand-name">TTP<span>Shop</span></span>
                        </div>
                        <p class="footer-desc">Nơi mua sắm tiện lợi, giao diện thân thiện, sản phẩm đa dạng và dịch vụ tận tâm.</p>
                        <p class="footer-desc small opacity-60">Mang trải nghiệm mua sắm hiện đại đến từng khách hàng.</p>
                        <!-- Social icons -->
                        <div class="d-flex gap-2 mt-3">
                            <a href="#" class="social-btn" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                            <a href="#" class="social-btn" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                            <a href="#" class="social-btn" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                            <a href="#" class="social-btn" aria-label="TikTok"><i class="bi bi-tiktok"></i></a>
                        </div>
                    </div>

                    <!-- Quick links -->
                    <div class="col-lg-2 col-md-6 col-6">
                        <h6 class="footer-heading">Liên kết nhanh</h6>
                        <ul class="footer-links">
                            <li><a asp-controller="Home" asp-action="Index"><i class="bi bi-chevron-right"></i>Trang chủ</a></li>
                            <li><a asp-controller="Product" asp-action="Index"><i class="bi bi-chevron-right"></i>Sản phẩm</a></li>
                            <li><a asp-controller="Cart" asp-action="Index"><i class="bi bi-chevron-right"></i>Giỏ hàng</a></li>
                            <li><a asp-controller="Order" asp-action="Index"><i class="bi bi-chevron-right"></i>Đơn hàng</a></li>
                            <li><a asp-controller="Home" asp-action="Privacy"><i class="bi bi-chevron-right"></i>Chính sách</a></li>
                        </ul>
                    </div>

                    <!-- Contact -->
                    <div class="col-lg-3 col-md-6 col-6">
                        <h6 class="footer-heading">Liên hệ</h6>
                        <ul class="footer-contact">
                            <li>
                                <span class="contact-icon"><i class="bi bi-geo-alt-fill"></i></span>
                                <span>Hà Nội, Việt Nam</span>
                            </li>
                            <li>
                                <span class="contact-icon"><i class="bi bi-telephone-fill"></i></span>
                                <span>0123 456 789</span>
                            </li>
                            <li>
                                <span class="contact-icon"><i class="bi bi-envelope-fill"></i></span>
                                <span>support@@ttpshop.vn</span>
                            </li>
                            <li>
                                <span class="contact-icon"><i class="bi bi-clock-fill"></i></span>
                                <span>8:00 – 22:00 mỗi ngày</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Trust badges -->
                    <div class="col-lg-3 col-md-6">
                        <h6 class="footer-heading">Cam kết của chúng tôi</h6>
                        <div class="trust-badges">
                            <div class="trust-item">
                                <span class="trust-icon"><i class="bi bi-patch-check-fill"></i></span>
                                <div>
                                    <div class="trust-title">Hàng chính hãng</div>
                                    <div class="trust-sub">100% sản phẩm có nguồn gốc</div>
                                </div>
                            </div>
                            <div class="trust-item">
                                <span class="trust-icon"><i class="bi bi-shield-fill-check"></i></span>
                                <div>
                                    <div class="trust-title">Thanh toán bảo mật</div>
                                    <div class="trust-sub">Mã hóa SSL an toàn tuyệt đối</div>
                                </div>
                            </div>
                            <div class="trust-item">
                                <span class="trust-icon"><i class="bi bi-arrow-repeat"></i></span>
                                <div>
                                    <div class="trust-title">Đổi trả dễ dàng</div>
                                    <div class="trust-sub">Miễn phí trong vòng 7 ngày</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer bottom -->
                <div class="footer-bottom">
                    <span>© 2026 TTP Shop. All rights reserved.</span>
                    <div class="footer-bottom-links">
                        <a asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a>
                        <span class="sep">·</span>
                        <a href="#">Điều khoản sử dụng</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
